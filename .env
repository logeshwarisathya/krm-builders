# KRM Planner and Builders — Environment Config
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Session secret — CHANGE THIS to a long random string in production!
SESSION_SECRET=krm-change-this-to-a-long-random-secret-string-2024

# Optional: email notifications when a new lead comes in
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=admin@krmbuilders.com
